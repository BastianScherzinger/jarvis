# JARVIS — Konfiguration
# Kopiere diese Datei zu .env und trage deine Keys ein.

# Anthropic API Key (Pflicht) — https://console.anthropic.com
ANTHROPIC_KEY=sk-ant-...

# TTS-Stimme (optional, Standard: de-DE-ConradNeural)
# Weitere Stimmen: en-GB-RyanNeural, de-DE-KillianNeural
# JARVIS_VOICE=de-DE-ConradNeural

# TTS-Geschwindigkeit (optional, Standard: +18%)
# JARVIS_RATE=+18%

# Spracherkennung — lokales Whisper-Modell (optional, Standard: base)
# tiny = 75 MB, ~100ms | base = 150 MB, ~300ms | small = 500 MB, ~800ms
# JARVIS_STT_MODEL=base

# TTS Stimme (edge-tts, Standard: de-DE-ConradNeural)
# JARVIS-Stil Englisch: en-GB-RyanNeural
# JARVIS_VOICE=de-DE-ConradNeural
# JARVIS_RATE=+15%

# Lokale Fallback-Stimme (pyttsx3 / Windows SAPI) — greift wenn edge-tts versagt
# Beliebiges Schluesselwort aus dem Stimm-Namen (z.B. "ryan", "stefan", "david")
# JARVIS_VOICE_LOCAL=ryan

# ElevenLabs Premium-Stimme (optional)
# Kostenlos: 10.000 Zeichen/Monat — https://elevenlabs.io
# ELEVENLABS_KEY=
# ELEVENLABS_VOICE=JBFqnCBsd6RMkjVDRZzb
